{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "paths": {
      "@/features/utils/material-icon": ["./src/utils/material-icon.ts"],
      "@/features/mathjax/load-mathjax": ["./src/utils/load-mathjax.ts"],
      "@/features/source-editor/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
